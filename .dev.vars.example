# ponytail: MLK — Local development secrets for Cloudflare Workers.
# Copy this file to .dev.vars and fill in real values.
# .dev.vars is gitignored — NEVER commit real secrets.
#
# For production: use `npx wrangler secret put <NAME>`

# Rotated hash salt (NOT the exposed 9fad3e8f... — that salt is dead)
# Generate with: openssl rand -hex 32
PIP_VOTER_HASH_SALT=your_rotated_salt_here

# JWT secret for auth (if enabled)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# CSRF secret
# Generate with: openssl rand -hex 32
CSRF_SECRET=your_csrf_secret_here

# App origin for CORS
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
